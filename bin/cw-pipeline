#!/bin/bash
#
# cw-pipeline - Full End-to-End Feature Development Orchestrator
#
# Single command: prompt → worktree → spec → plan → execute → validate →
#                 review → test → fix → re-validate → PR
#
# Usage:
#   ./cw-pipeline [OPTIONS]
#
# Single Feature:
#   cw-pipeline --prompt "Build JWT auth" --name auth
#   cw-pipeline --spec docs/specs/01-spec-auth.md --name auth
#
# Resume:
#   cw-pipeline --resume --name auth
#   cw-pipeline --resume --from 4 --name auth
#
# Multiple Features (parallel):
#   cw-pipeline \
#     --feature "auth:prompt:Build JWT authentication" \
#     --feature "billing:spec:docs/specs/02-spec-billing.md"
#
# Options:
#   --prompt TEXT          Feature description (single feature mode)
#   --spec PATH           Existing spec file (single feature mode)
#   --name NAME           Feature name for worktree/branch (single feature mode)
#   --feature SPEC        Multi-feature spec (format: name:prompt:text or name:spec:path)
#   --resume              Resume from last checkpoint
#   --from N              Force resume from stage N (1-9, requires --resume)
#   --no-worktree         Run in current directory (skip worktree creation)
#   --no-test             Skip test phase
#   --no-pr               Skip PR creation
#   --no-review           Skip code review stage
#   --auto-pr             Create PR without pausing for confirmation
#   --force               Bypass the PR gate even if a validate/review gate did not PASS
#   -m, --model MODEL     Claude model to use (default: sonnet)
#   -v, --verbose         Stream JSON output for real-time visibility
#   -h, --help            Show this help message
#
# Exit Codes:
#   0  All features completed successfully
#   1  One or more features failed
#   4  Missing dependencies or invalid arguments
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/cw-common.sh"

# =============================================================================
# Configuration
# =============================================================================

# Single feature mode
SINGLE_PROMPT=""
SINGLE_SPEC=""
SINGLE_NAME=""

# Multi-feature mode (indexed arrays for Bash 3.2)
FEATURE_NAMES=()
FEATURE_MODES=()
FEATURE_VALUES=()

# Pipeline flags
NO_WORKTREE=false
NO_TEST=false
NO_PR=false
NO_REVIEW=false
AUTO_PR=false
CW_FORCE=false

# Gate verdicts (PASS | FAIL | Unknown) — populated by validate/review stages,
# enforced at the PR stage. Default Unknown: an unrun gate never counts as PASS.
GATE_VALIDATE="Unknown"
GATE_REVIEW="Unknown"
GATE_REVALIDATE="Unknown"

# Resume flags
CW_RESUME=false
CW_FROM_STAGE=""

# Track which flags were explicitly set on CLI (for resume precedence)
NO_TEST_SET=false
NO_REVIEW_SET=false
NO_PR_SET=false
NO_WORKTREE_SET=false
AUTO_PR_SET=false
MODEL_SET=false
VERBOSE_SET=false
FORCE_SET=false

# =============================================================================
# Argument Parsing
# =============================================================================

show_help() {
    echo "Usage: cw-pipeline [OPTIONS]"
    echo ""
    echo "Full end-to-end feature development orchestrator."
    echo ""
    echo "Single Feature:"
    echo "  cw-pipeline --prompt 'Build JWT auth' --name auth"
    echo "  cw-pipeline --spec docs/specs/01-spec-auth.md --name auth"
    echo ""
    echo "Resume:"
    echo "  cw-pipeline --resume --name auth"
    echo "  cw-pipeline --resume --from 4 --name auth"
    echo ""
    echo "Multiple Features (parallel):"
    echo "  cw-pipeline \\"
    echo "    --feature 'auth:prompt:Build JWT authentication' \\"
    echo "    --feature 'billing:spec:docs/specs/02-spec-billing.md'"
    echo ""
    echo "Options:"
    echo "  --prompt TEXT        Feature description (single feature mode)"
    echo "  --spec PATH         Existing spec file (single feature mode)"
    echo "  --name NAME         Feature name for worktree/branch"
    echo "  --feature SPEC      Multi-feature (format: name:prompt:text or name:spec:path)"
    echo "  --resume            Resume from last checkpoint"
    echo "  --from N            Force resume from stage N (1-9, requires --resume)"
    echo "  --no-worktree       Run in current directory"
    echo "  --no-test           Skip test phase"
    echo "  --no-pr             Skip PR creation"
    echo "  --no-review         Skip code review stage"
    echo "  --auto-pr           Create PR without confirmation"
    echo "  --force             Bypass PR gate on a non-PASS validate/review gate"
    echo "  -m, --model MODEL   Claude model (default: $CW_MODEL)"
    echo "  -v, --verbose       Stream JSON output for real-time visibility"
    echo "  -h, --help          Show this help"
    echo ""
    echo "Pipeline Stages:"
    echo "  1. Create worktree (unless --no-worktree)"
    echo "  2. Init (spec + plan via cw-init)"
    echo "  3. Execute tasks (cw-loop -d)"
    echo "  4. Validate (/cw-validate)"
    echo "  5. Code review (unless --no-review)"
    echo "  6. Test init (unless --no-test)"
    echo "  7. Test loop (unless --no-test)"
    echo "  8. Re-validate (/cw-validate)"
    echo "  9. PR creation (unless --no-pr)"
    echo ""
    echo "Exit Codes:"
    echo "  0  All features completed successfully"
    echo "  1  One or more features failed"
    echo "  4  Missing dependencies or invalid arguments"
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --prompt) require_arg "--prompt" "${2:-}"; SINGLE_PROMPT="$2"; shift 2 ;;
        --spec) require_arg "--spec" "${2:-}"; SINGLE_SPEC="$2"; shift 2 ;;
        --name) require_arg "--name" "${2:-}"; SINGLE_NAME="$2"; shift 2 ;;
        --feature)
            require_arg "--feature" "${2:-}"
            # Parse format: name:mode:value
            local_spec="$2"
            local_name="${local_spec%%:*}"
            local_rest="${local_spec#*:}"
            local_mode="${local_rest%%:*}"
            local_value="${local_rest#*:}"

            FEATURE_NAMES+=("$local_name")
            FEATURE_MODES+=("$local_mode")
            FEATURE_VALUES+=("$local_value")
            shift 2
            ;;
        --resume) CW_RESUME=true; shift ;;
        --from) require_arg "--from" "${2:-}"; CW_FROM_STAGE="$2"; shift 2 ;;
        --no-worktree) NO_WORKTREE=true; NO_WORKTREE_SET=true; shift ;;
        --no-test) NO_TEST=true; NO_TEST_SET=true; shift ;;
        --no-pr) NO_PR=true; NO_PR_SET=true; shift ;;
        --no-review) NO_REVIEW=true; NO_REVIEW_SET=true; shift ;;
        --auto-pr) AUTO_PR=true; AUTO_PR_SET=true; shift ;;
        --force) CW_FORCE=true; FORCE_SET=true; shift ;;
        -m|--model) require_arg "--model" "${2:-}"; CW_MODEL="$2"; MODEL_SET=true; shift 2 ;;
        -v|--verbose) CW_VERBOSE=true; VERBOSE_SET=true; shift ;;
        -h|--help) show_help; exit 0 ;;
        -*) log_error "Unknown option: $1"; show_help; exit 4 ;;
        *) log_error "Unexpected argument: $1"; show_help; exit 4 ;;
    esac
done

# =============================================================================
# Preflight Checks
# =============================================================================

check_jq || exit 4
check_claude || exit 4

# Validate --from requires --resume
if [ -n "$CW_FROM_STAGE" ] && [ "$CW_RESUME" != "true" ]; then
    log_error "--from requires --resume"
    exit 4
fi

# Validate --from is a valid stage number
if [ -n "$CW_FROM_STAGE" ]; then
    if ! [[ "$CW_FROM_STAGE" =~ ^[1-9]$ ]]; then
        log_error "--from must be a stage number between 1 and 9"
        exit 4
    fi
fi

# Validate arguments
if [ ${#FEATURE_NAMES[@]} -eq 0 ]; then
    # Single feature mode
    if [ -z "$SINGLE_NAME" ]; then
        log_error "--name is required (provides the feature name for worktree/branch)"
        show_help
        exit 4
    fi

    if [ "$CW_RESUME" = "true" ]; then
        # Resume mode: prompt/spec not required, will be read from state file
        FEATURE_NAMES+=("$SINGLE_NAME")
        FEATURE_MODES+=("resume")
        FEATURE_VALUES+=("")
    elif [ -z "$SINGLE_PROMPT" ] && [ -z "$SINGLE_SPEC" ]; then
        log_error "Either --prompt or --spec is required"
        show_help
        exit 4
    else
        # Convert to multi-feature format (array of 1)
        FEATURE_NAMES+=("$SINGLE_NAME")
        if [ -n "$SINGLE_PROMPT" ]; then
            FEATURE_MODES+=("prompt")
            FEATURE_VALUES+=("$SINGLE_PROMPT")
        else
            FEATURE_MODES+=("spec")
            FEATURE_VALUES+=("$SINGLE_SPEC")
        fi
    fi
fi

print_banner "Claude Workflow - Pipeline"

log_info "Features: ${#FEATURE_NAMES[@]}"
for i in "${!FEATURE_NAMES[@]}"; do
    log_info "  ${FEATURE_NAMES[$i]} (${FEATURE_MODES[$i]})"
done
log_info "Model: $CW_MODEL"
log_info "Resume: $([ "$CW_RESUME" = true ] && echo "yes$([ -n "$CW_FROM_STAGE" ] && echo " (from stage $CW_FROM_STAGE)")" || echo "no")"
log_info "Worktree: $([ "$NO_WORKTREE" = true ] && echo "disabled" || echo "enabled")"
log_info "Tests: $([ "$NO_TEST" = true ] && echo "disabled" || echo "enabled")"
log_info "Review: $([ "$NO_REVIEW" = true ] && echo "disabled" || echo "enabled")"
log_info "PR: $([ "$NO_PR" = true ] && echo "disabled" || echo "auto-pr=$AUTO_PR")"
log_info "PR gate: $([ "$CW_FORCE" = true ] && echo "forced (validate/review veto bypassed)" || echo "enforced (validate + review must PASS)")"

# =============================================================================
# Gate Verdict Parsing (hard PR gate)
# =============================================================================
#
# Validate/review skills end with a machine-readable trailer:
#   cw-validate     -> "VERDICT: PASS"  | "VERDICT: FAIL"
#   cw-review[-team] -> "VERDICT: APPROVED" | "VERDICT: CHANGES_REQUESTED"
# Classify the last such line into PASS | FAIL | Unknown. Per the agreement rule
# in skills/cw-review-team/references/quorum-verification.md (rule 1: abstain ≠
# pass), a missing or unparseable verdict is Unknown — never PASS.

# Classify captured skill output into a gate verdict.
# Usage: _gate_verdict_from_output OUTPUT
_gate_verdict_from_output() {
    local output="$1"
    local line
    line=$(echo "$output" | grep -iE '^[[:space:]]*VERDICT:' | tail -1)
    # Conservative default: a verdict that names FAIL / CHANGES_REQUESTED at all
    # (even alongside PASS, e.g. an unresolved "PASS | FAIL" template) blocks.
    case "$line" in
        *[Ff][Aa][Ii][Ll]*|*[Cc][Hh][Aa][Nn][Gg][Ee][Ss]_[Rr][Ee][Qq][Uu][Ee][Ss][Tt][Ee][Dd]*) echo "FAIL" ;;
        *[Pp][Aa][Ss][Ss]*|*[Aa][Pp][Pp][Rr][Oo][Vv][Ee][Dd]*) echo "PASS" ;;
        *) echo "Unknown" ;;
    esac
}

# Persist a gate verdict into the pipeline state file so a resumed run that
# re-enters the PR stage still sees it. Best-effort; never aborts the pipeline.
# Usage: _gate_verdict_save WORK_DIR GATE_KEY VERDICT
_gate_verdict_save() {
    local work_dir="$1" gate_key="$2" verdict="$3"
    local state_file="$work_dir/$PIPELINE_STATE_FILE"
    [ -f "$state_file" ] || return 0
    local tmp_file
    tmp_file=$(mktemp)
    jq --arg k "$gate_key" --arg v "$verdict" \
        '.gates = (.gates // {}) | .gates[$k] = $v | .updated_at = (now | todate)' \
        "$state_file" > "$tmp_file" 2>/dev/null && mv "$tmp_file" "$state_file" || rm -f "$tmp_file"
}

# Read a previously persisted gate verdict (for resumed runs).
# Usage: _gate_verdict_load WORK_DIR GATE_KEY  -> prints verdict or "Unknown"
_gate_verdict_load() {
    local work_dir="$1" gate_key="$2"
    local state_file="$work_dir/$PIPELINE_STATE_FILE"
    [ -f "$state_file" ] || { echo "Unknown"; return 0; }
    jq -r --arg k "$gate_key" '.gates[$k] // "Unknown"' "$state_file" 2>/dev/null || echo "Unknown"
}

# Invoke a verification skill, keep its output visible, and classify the verdict.
# Sets the named gate variable to PASS | FAIL | Unknown. Returns invoke_claude's
# exit code so callers can still distinguish CLI failure from a FAIL verdict.
# Usage: _run_gate WORK_DIR GATE_KEY GATE_VAR PROMPT
_run_gate() {
    local work_dir="$1" gate_key="$2" gate_var="$3" prompt="$4"
    local out_file invoke_rc=0 captured verdict
    out_file=$(mktemp)
    # tee keeps the skill's report visible while capturing it for verdict parsing.
    # pipefail so the pipe reports invoke_claude's exit, not tee's; restore after.
    local had_pipefail=false
    if set -o | grep -q 'pipefail[[:space:]]*on'; then had_pipefail=true; fi
    set -o pipefail
    invoke_claude "$prompt" "$CW_MODEL" | tee "$out_file" || invoke_rc=$?
    if [ "$had_pipefail" = false ]; then set +o pipefail; fi
    captured=$(cat "$out_file")
    rm -f "$out_file"
    # A missing/unparseable verdict — including one from a crashed invocation —
    # classifies as Unknown (abstain ≠ pass), never PASS.
    verdict=$(_gate_verdict_from_output "$captured")
    printf -v "$gate_var" '%s' "$verdict"
    _gate_verdict_save "$work_dir" "$gate_key" "$verdict"
    return "$invoke_rc"
}

# =============================================================================
# Feature Pipeline Function
# =============================================================================

# Run the full pipeline for a single feature
# Arguments: FEATURE_NAME MODE VALUE
# MODE: "prompt" or "spec"
# VALUE: prompt text or spec path
run_feature_pipeline() {
    local feature_name="$1"
    local mode="$2"
    local value="$3"
    local original_dir
    original_dir="$(pwd)"
    local work_dir="$original_dir"
    local start_stage=1

    log_header "Pipeline: $feature_name"

    # ─── Resume Logic ─────────────────────────────────────────────────────
    if [ "$CW_RESUME" = "true" ]; then
        # Locate worktree
        if [ "$NO_WORKTREE" = false ]; then
            local worktree_dir=".worktrees/feature-${feature_name}"
            if [ ! -d "$worktree_dir" ]; then
                log_error "No worktree found for feature '$feature_name' at $worktree_dir"
                log_info "Cannot resume — no previous run found"
                return 1
            fi
            work_dir="$(cd "$worktree_dir" && pwd)"
        fi

        # Read state file
        if ! pipeline_state_exists "$work_dir"; then
            log_error "No pipeline state file found in $work_dir"
            log_info "Cannot resume — run the pipeline without --resume first"
            return 1
        fi

        # Restore flags from state file (CLI overrides take precedence)
        pipeline_read_flags "$work_dir"
        mode="$RESUME_MODE"
        value="$RESUME_VALUE"

        # Determine resume point
        if [ -n "$CW_FROM_STAGE" ]; then
            start_stage="$CW_FROM_STAGE"
            log_info "[$feature_name] Forced resume from stage $start_stage"
        else
            start_stage=$(pipeline_get_resume_stage "$work_dir")
            if [ "$start_stage" = "done" ]; then
                log_success "[$feature_name] Pipeline already completed — nothing to resume"
                return 0
            fi
            log_info "[$feature_name] Resuming from stage $start_stage ($(_pipeline_stage_name "$start_stage"))"
        fi

        # cd into worktree for resumed runs
        if [ "$NO_WORKTREE" = false ]; then
            cd "$work_dir"
        fi
    else
        # Fresh run — check for existing state file after worktree is resolved
        # (state file check happens after stage 1 creates/locates the worktree)
        :
    fi

    # ─── Stage 1: Create Worktree ─────────────────────────────────────────
    if [ "$start_stage" -le 1 ]; then
        if [ "$NO_WORKTREE" = false ]; then
            pipeline_checkpoint "$work_dir" "1" "in_progress" 2>/dev/null || true
            log_info "[$feature_name] Stage 1: Creating worktree..."

            if ! create_worktree "$feature_name"; then
                log_error "[$feature_name] Failed to create worktree"
                pipeline_checkpoint "$work_dir" "1" "failed" 2>/dev/null || true
                return 1
            fi

            work_dir="$CW_WORKTREE_PATH"
            cd "$work_dir"
            log_success "[$feature_name] Worktree: $work_dir"
        else
            log_info "[$feature_name] Stage 1: Skipped (--no-worktree)"
        fi

        # Initialize state file for fresh runs (now that work_dir is resolved)
        if [ "$CW_RESUME" != "true" ]; then
            if pipeline_state_exists "$work_dir"; then
                log_error "Pipeline state file already exists in $work_dir"
                log_info "Use --resume to continue, or delete $work_dir/$PIPELINE_STATE_FILE to restart"
                cd "$original_dir"
                return 1
            fi
            pipeline_state_init "$work_dir" "$feature_name" "$mode" "$value"
        fi

        if [ "$NO_WORKTREE" = false ]; then
            pipeline_checkpoint "$work_dir" "1" "completed"
        else
            pipeline_checkpoint "$work_dir" "1" "skipped"
        fi
    else
        log_info "[$feature_name] Stage 1: Already completed"
    fi

    # ─── Stage 2: Init (Spec + Plan) ─────────────────────────────────────
    if [ "$start_stage" -le 2 ]; then
        pipeline_checkpoint "$work_dir" "2" "in_progress"
        log_info "[$feature_name] Stage 2: Init (spec + plan)..."

        # Idempotency: check if spec + tasks already exist
        local skip_init=false
        if [ "$CW_RESUME" = "true" ]; then
            local has_spec=false
            local has_tasks=false
            if ls docs/specs/*.md 2>/dev/null | head -1 | grep -q .; then
                has_spec=true
            fi
            if discover_session "$work_dir" 2>/dev/null; then
                if _has_task_files 2>/dev/null; then
                    has_tasks=true
                fi
            fi
            if [ "$has_spec" = true ] && [ "$has_tasks" = true ]; then
                log_info "[$feature_name] Spec and tasks already exist, skipping init"
                skip_init=true
            fi
        fi

        if [ "$skip_init" = false ]; then
            local init_args=(-m "$CW_MODEL")
            if [ "$CW_VERBOSE" = "true" ]; then
                init_args+=(-v)
            fi

            if [ "$mode" = "prompt" ]; then
                init_args+=(--prompt "$value")
            else
                init_args+=(--spec "$value")
            fi

            if ! "$SCRIPT_DIR/cw-init" "${init_args[@]}"; then
                log_error "[$feature_name] Init failed"
                pipeline_checkpoint "$work_dir" "2" "failed"
                cd "$original_dir"
                return 1
            fi
        fi

        log_success "[$feature_name] Init completed"
        pipeline_checkpoint "$work_dir" "2" "completed"
    else
        log_info "[$feature_name] Stage 2: Already completed"
    fi

    # ─── Stage 3: Execute Tasks ───────────────────────────────────────────
    if [ "$start_stage" -le 3 ]; then
        pipeline_checkpoint "$work_dir" "3" "in_progress"
        log_info "[$feature_name] Stage 3: Executing tasks..."

        local loop_args=(-d -m "$CW_MODEL")
        if [ "$CW_VERBOSE" = "true" ]; then
            loop_args+=(-v)
        fi

        # cw-loop is already idempotent (checks is_complete on entry)
        local stage3_ok=true
        CW_NON_INTERACTIVE=true "$SCRIPT_DIR/cw-loop" "${loop_args[@]}" "$work_dir" || {
            local loop_exit=$?
            if [ "$loop_exit" -ne 0 ]; then
                log_warning "[$feature_name] Task execution exited with code $loop_exit"
                stage3_ok=false
            fi
        }

        if [ "$stage3_ok" = true ]; then
            log_success "[$feature_name] Task execution completed"
            pipeline_checkpoint "$work_dir" "3" "completed"
        else
            log_warning "[$feature_name] Task execution had failures (continuing pipeline)"
            pipeline_checkpoint "$work_dir" "3" "failed"
        fi
    else
        log_info "[$feature_name] Stage 3: Already completed"
    fi

    # ─── Stage 4: Validate ────────────────────────────────────────────────
    if [ "$start_stage" -le 4 ]; then
        pipeline_checkpoint "$work_dir" "4" "in_progress"
        log_info "[$feature_name] Stage 4: Validation (first pass)..."

        discover_session "$work_dir" 2>/dev/null || true

        local validate_prompt="Use the Skill tool to invoke 'cw-validate'.

Run the 6-gate validation against the spec. This is running non-interactively — proceed autonomously without using AskUserQuestion."

        _run_gate "$work_dir" "validate" GATE_VALIDATE "$validate_prompt" || true
        if [ "$GATE_VALIDATE" = "PASS" ]; then
            log_success "[$feature_name] Validation PASSED"
            pipeline_checkpoint "$work_dir" "4" "completed"
        else
            log_warning "[$feature_name] Validation verdict: $GATE_VALIDATE (continuing pipeline; PR stage will gate on this)"
            pipeline_checkpoint "$work_dir" "4" "failed"
        fi
    else
        log_info "[$feature_name] Stage 4: Already completed"
    fi

    # ─── Stage 5: Code Review ────────────────────────────────────────────
    if [ "$start_stage" -le 5 ]; then
        if [ "$NO_REVIEW" = false ]; then
            pipeline_checkpoint "$work_dir" "5" "in_progress"
            log_info "[$feature_name] Stage 5: Code review..."

            local review_prompt="Use the Skill tool to invoke 'cw-review'.

Review all code changes on this branch against the spec and repository standards. Create FIX-REVIEW tasks for any blocking issues found.

This is running non-interactively — proceed autonomously without using AskUserQuestion."

            _run_gate "$work_dir" "review" GATE_REVIEW "$review_prompt" || true

            # Execute any FIX-REVIEW tasks the review raised, regardless of verdict.
            local fix_count
            fix_count=$(get_pending_fix_count 2>/dev/null || echo "0")
            if [ "$fix_count" -gt 0 ]; then
                log_info "[$feature_name] Executing $fix_count review fix task(s)..."
                CW_NON_INTERACTIVE=true "$SCRIPT_DIR/cw-loop" -m "$CW_MODEL" "$work_dir" || true
            fi

            if [ "$GATE_REVIEW" = "PASS" ]; then
                log_success "[$feature_name] Code review APPROVED"
                pipeline_checkpoint "$work_dir" "5" "completed"
            else
                log_warning "[$feature_name] Review verdict: $GATE_REVIEW (continuing; PR stage will gate on this)"
                pipeline_checkpoint "$work_dir" "5" "failed"
            fi
        else
            log_info "[$feature_name] Stage 5: Skipped (--no-review)"
            GATE_REVIEW="skipped"
            _gate_verdict_save "$work_dir" "review" "skipped"
            pipeline_checkpoint "$work_dir" "5" "skipped"
        fi
    else
        log_info "[$feature_name] Stage 5: Already completed"
    fi

    # ─── Stage 6: Test Init ──────────────────────────────────────────────
    if [ "$start_stage" -le 6 ]; then
        if [ "$NO_TEST" = false ]; then
            pipeline_checkpoint "$work_dir" "6" "in_progress"
            log_info "[$feature_name] Stage 6: Test init..."

            # Idempotency: check for existing TEST-* tasks
            local skip_test_init=false
            if discover_session "$work_dir" 2>/dev/null && _has_task_files 2>/dev/null; then
                local test_task_count
                test_task_count=$(_slurp_tasks '[.[] | select(.metadata.task_id // "" | test("^TEST"; "i"))] | length' 2>/dev/null || echo "0")
                if [ "$test_task_count" -gt 0 ]; then
                    log_info "[$feature_name] TEST tasks already exist ($test_task_count found), skipping test init"
                    skip_test_init=true
                fi
            fi

            if [ "$skip_test_init" = false ]; then
                local test_init_args=(-m "$CW_MODEL")
                if [ "$CW_VERBOSE" = "true" ]; then
                    test_init_args+=(-v)
                fi

                if [ "$mode" = "spec" ]; then
                    test_init_args+=(--spec "$value")
                else
                    test_init_args+=(--prompt "$value")
                fi

                if "$SCRIPT_DIR/cw-test-init" "${test_init_args[@]}"; then
                    # Defense-in-depth: verify test tasks exist even after cw-test-init reports success
                    if discover_session "$work_dir" 2>/dev/null && _has_task_files 2>/dev/null; then
                        local verified_test_count
                        verified_test_count=$(_slurp_tasks '[.[] | select(
                            (.metadata.test_status != null) or
                            (.metadata.test_type == "e2e") or
                            (.subject | test("^TEST"; "i")) or
                            (.metadata.task_id // "" | test("^TEST"; "i"))
                        ) | select(.metadata.test_suite != true)] | length' 2>/dev/null || echo "0")

                        if [ "$verified_test_count" -eq 0 ]; then
                            log_warning "[$feature_name] Test init reported success but no test tasks found"
                            pipeline_checkpoint "$work_dir" "6" "failed"
                        else
                            log_success "[$feature_name] Test init completed ($verified_test_count test tasks)"
                            pipeline_checkpoint "$work_dir" "6" "completed"
                        fi
                    else
                        log_warning "[$feature_name] Test init reported success but could not verify tasks"
                        pipeline_checkpoint "$work_dir" "6" "failed"
                    fi
                else
                    log_warning "[$feature_name] Test init failed (continuing)"
                    pipeline_checkpoint "$work_dir" "6" "failed"
                fi
            else
                pipeline_checkpoint "$work_dir" "6" "completed"
            fi
        else
            log_info "[$feature_name] Stage 6: Skipped (--no-test)"
            pipeline_checkpoint "$work_dir" "6" "skipped"
        fi
    else
        log_info "[$feature_name] Stage 6: Already completed"
    fi

    # ─── Stage 7: Test Loop ──────────────────────────────────────────────
    if [ "$start_stage" -le 7 ]; then
        if [ "$NO_TEST" = false ]; then
            pipeline_checkpoint "$work_dir" "7" "in_progress"
            log_info "[$feature_name] Stage 7: Test loop..."

            local test_loop_args=(-m "$CW_MODEL")
            if [ "$CW_VERBOSE" = "true" ]; then
                test_loop_args+=(-v)
            fi

            # cw-test-loop is already idempotent
            local stage7_ok=true
            "$SCRIPT_DIR/cw-test-loop" "${test_loop_args[@]}" "$work_dir" || {
                local test_exit=$?
                log_warning "[$feature_name] Test loop exited with code $test_exit"
                stage7_ok=false
            }
            if [ "$stage7_ok" = true ]; then
                pipeline_checkpoint "$work_dir" "7" "completed"
            else
                pipeline_checkpoint "$work_dir" "7" "failed"
            fi
        else
            log_info "[$feature_name] Stage 7: Skipped (--no-test)"
            pipeline_checkpoint "$work_dir" "7" "skipped"
        fi
    else
        log_info "[$feature_name] Stage 7: Already completed"
    fi

    # ─── Stage 8: Re-Validate ────────────────────────────────────────────
    if [ "$start_stage" -le 8 ]; then
        pipeline_checkpoint "$work_dir" "8" "in_progress"
        log_info "[$feature_name] Stage 8: Final validation..."

        discover_session "$work_dir" 2>/dev/null || true

        local revalidate_prompt="Use the Skill tool to invoke 'cw-validate'.

Run the final 6-gate validation against the spec. This is the last check before PR creation. This is running non-interactively — proceed autonomously without using AskUserQuestion."

        _run_gate "$work_dir" "revalidate" GATE_REVALIDATE "$revalidate_prompt" || true
        if [ "$GATE_REVALIDATE" = "PASS" ]; then
            log_success "[$feature_name] Final validation PASSED"
            pipeline_checkpoint "$work_dir" "8" "completed"
        else
            log_warning "[$feature_name] Final validation verdict: $GATE_REVALIDATE (PR stage will gate on this)"
            pipeline_checkpoint "$work_dir" "8" "failed"
        fi
    else
        log_info "[$feature_name] Stage 8: Already completed"
    fi

    # ─── Stage 9: PR Creation ────────────────────────────────────────────
    if [ "$start_stage" -le 9 ]; then
        if [ "$NO_PR" = false ]; then
            pipeline_checkpoint "$work_dir" "9" "in_progress"
            log_info "[$feature_name] Stage 9: PR creation..."

            # ── Hard PR gate ─────────────────────────────────────────────
            # The PR stage trusts no agent's self-report: it gates on the
            # recorded validate/review verdicts, not on whether the skill ran.
            # Gates compose with AND (quorum rule 3) — every required gate must
            # be PASS. A non-PASS verdict (FAIL or Unknown) blocks the PR;
            # abstain ≠ pass (rule 1). Only --force or an explicit human
            # override at this irreversible boundary bypasses (rule 4), logged.
            #
            # On resume the in-memory verdicts may be unset — fall back to the
            # values persisted by the validate/review stages.
            if [ "$GATE_VALIDATE" = "Unknown" ]; then GATE_VALIDATE=$(_gate_verdict_load "$work_dir" "validate"); fi
            if [ "$GATE_REVIEW" = "Unknown" ]; then GATE_REVIEW=$(_gate_verdict_load "$work_dir" "review"); fi
            if [ "$GATE_REVALIDATE" = "Unknown" ]; then GATE_REVALIDATE=$(_gate_verdict_load "$work_dir" "revalidate"); fi

            local pr_blocked=false
            local blocking_gates=""
            if [ "$GATE_VALIDATE" != "PASS" ]; then
                pr_blocked=true; blocking_gates="${blocking_gates} validate=$GATE_VALIDATE"
            fi
            if [ "$NO_REVIEW" = false ] && [ "$GATE_REVIEW" != "PASS" ] && [ "$GATE_REVIEW" != "skipped" ]; then
                pr_blocked=true; blocking_gates="${blocking_gates} review=$GATE_REVIEW"
            fi
            if [ "$GATE_REVALIDATE" != "PASS" ]; then
                pr_blocked=true; blocking_gates="${blocking_gates} revalidate=$GATE_REVALIDATE"
            fi

            if [ "$pr_blocked" = true ]; then
                if [ "$CW_FORCE" = true ]; then
                    log_warning "[$feature_name] PR gate FAILED (${blocking_gates# }) — bypassed by --force"
                elif [ "$AUTO_PR" = true ] || [ "${CW_NON_INTERACTIVE}" = "true" ]; then
                    log_error "[$feature_name] PR gate FAILED (${blocking_gates# }) — refusing to open PR"
                    log_info "[$feature_name] Fix the failing gate(s) and re-run, or pass --force to override"
                    pipeline_checkpoint "$work_dir" "9" "failed"
                    cd "$original_dir"
                    return 1
                else
                    echo ""
                    echo -e "${YELLOW}[$feature_name] PR gate FAILED:${NC}${blocking_gates}"
                    echo "Create the PR anyway? Type 'y' to override, anything else to abort..."
                    read -r gate_override
                    if [ "$gate_override" != "y" ] && [ "$gate_override" != "Y" ]; then
                        log_error "[$feature_name] PR creation aborted by human (gate not overridden)"
                        pipeline_checkpoint "$work_dir" "9" "failed"
                        cd "$original_dir"
                        return 1
                    fi
                    log_warning "[$feature_name] PR gate overridden by human at confirmation prompt"
                fi
            else
                log_success "[$feature_name] PR gate PASSED (validate + review + revalidate)"
            fi

            # Idempotency: check if PR already exists
            local stage9_ok=true
            local existing_pr
            existing_pr=$(gh pr list --head "feature/${feature_name}" --state open --json number --jq '.[0].number' 2>/dev/null || echo "")
            if [ -n "$existing_pr" ]; then
                log_info "[$feature_name] PR #$existing_pr already exists, skipping creation"
            elif [ "$AUTO_PR" = true ] || [ "${CW_NON_INTERACTIVE}" = "true" ]; then
                local pr_prompt="Create a pull request for this feature branch using 'gh pr create'.

Summarize all changes, reference the spec, and include a test plan. Use a descriptive title and body.

This is running non-interactively — create the PR without asking for confirmation."

                if invoke_claude "$pr_prompt" "$CW_MODEL"; then
                    log_success "[$feature_name] PR created"
                else
                    log_warning "[$feature_name] PR creation failed"
                    stage9_ok=false
                fi
            else
                echo ""
                echo -e "${YELLOW}[$feature_name] Ready to create PR.${NC}"
                echo "Press Enter to create PR, or 's' to skip..."
                read -r pr_action

                if [ "$pr_action" != "s" ] && [ "$pr_action" != "S" ]; then
                    local pr_prompt="Create a pull request for this feature branch using 'gh pr create'.

Summarize all changes, reference the spec, and include a test plan. Use a descriptive title and body."

                    if invoke_claude "$pr_prompt" "$CW_MODEL"; then
                        log_success "[$feature_name] PR created"
                    else
                        log_warning "[$feature_name] PR creation failed"
                        stage9_ok=false
                    fi
                else
                    log_info "[$feature_name] PR creation skipped"
                fi
            fi
            if [ "$stage9_ok" = true ]; then
                pipeline_checkpoint "$work_dir" "9" "completed"
            else
                pipeline_checkpoint "$work_dir" "9" "failed"
            fi
        else
            log_info "[$feature_name] Stage 9: Skipped (--no-pr)"
            pipeline_checkpoint "$work_dir" "9" "skipped"
        fi
    else
        log_info "[$feature_name] Stage 9: Already completed"
    fi

    # Return to original directory
    cd "$original_dir"
    log_success "[$feature_name] Pipeline completed"
    return 0
}

# =============================================================================
# Execution
# =============================================================================

START_TIME=$(date +%s)

if [ ${#FEATURE_NAMES[@]} -eq 1 ]; then
    # ── Single Feature ────────────────────────────────────────────────────
    run_feature_pipeline "${FEATURE_NAMES[0]}" "${FEATURE_MODES[0]}" "${FEATURE_VALUES[0]}"
    EXIT_CODE=$?

    ELAPSED=$(($(date +%s) - START_TIME))
    echo ""
    if [ "$EXIT_CODE" -eq 0 ]; then
        log_success "Pipeline completed successfully (Runtime: $(format_elapsed $ELAPSED))"
    else
        log_error "Pipeline failed (Runtime: $(format_elapsed $ELAPSED))"
    fi

    exit $EXIT_CODE
else
    # ── Multiple Features (Parallel) ─────────────────────────────────────
    log_header "Launching ${#FEATURE_NAMES[@]} features in parallel"

    for i in "${!FEATURE_NAMES[@]}"; do
        local_name="${FEATURE_NAMES[$i]}"
        local_mode="${FEATURE_MODES[$i]}"
        local_value="${FEATURE_VALUES[$i]}"

        log_info "Starting: $local_name ($local_mode)"

        # Each feature runs in a subshell as a background process
        # Redirect output to a log file per feature
        local log_file="/tmp/cw-pipeline-${local_name}.log"
        (
            run_feature_pipeline "$local_name" "$local_mode" "$local_value"
        ) > "$log_file" 2>&1 &

        register_pid $! "$local_name"
    done

    # Monitor until all complete
    log_info "Monitoring ${#PID_LIST[@]} background pipeline(s)..."
    monitor_pids 30

    # Show results
    get_pipeline_results
    PIPELINE_RESULT=$?

    ELAPSED=$(($(date +%s) - START_TIME))
    echo ""

    # Show log file locations
    log_info "Feature logs:"
    for i in "${!FEATURE_NAMES[@]}"; do
        echo "  ${FEATURE_NAMES[$i]}: /tmp/cw-pipeline-${FEATURE_NAMES[$i]}.log"
    done
    echo ""

    if [ "$PIPELINE_RESULT" -eq 0 ]; then
        log_success "All features completed successfully (Runtime: $(format_elapsed $ELAPSED))"
        exit 0
    else
        log_error "Some features failed (Runtime: $(format_elapsed $ELAPSED))"
        exit 1
    fi
fi
