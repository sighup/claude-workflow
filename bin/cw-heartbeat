#!/bin/bash
#
# cw-heartbeat - Linear Issue Pipeline Runner
#
# Pulls assigned issues from Linear and feeds them through the
# claude-workflow pipeline (spec → plan → dispatch → validate).
#
# Usage:
#   ./cw-heartbeat [OPTIONS]
#
# Options:
#   --dry-run             Show what would be processed without executing
#   --issue ID            Process a specific Linear issue by ID
#   --skip-spec           Skip spec generation (issue has existing spec)
#   --max N               Override max_issues_per_heartbeat
#   -m, --model MODEL     Claude model to use (default: sonnet)
#   -v, --verbose         Stream JSON output for real-time visibility
#   -h, --help            Show this help message
#
# Requires:
#   - .claude-workflow/config.yaml (run /cw-linear-init first)
#   - Linear MCP server configured in Claude Code
#   - jq
#
# Exit Codes:
#   0  All issues processed successfully
#   1  One or more issues failed
#   3  No issues to process
#   4  Missing dependencies or configuration
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/cw-common.sh"

# =============================================================================
# Configuration
# =============================================================================

DRY_RUN=false
ISSUE_ID=""
SKIP_SPEC=false
MAX_OVERRIDE=""

# =============================================================================
# Argument Parsing
# =============================================================================

show_help() {
    echo "Usage: cw-heartbeat [OPTIONS]"
    echo ""
    echo "Pull assigned issues from Linear and run them through the cw pipeline."
    echo ""
    echo "Options:"
    echo "  --dry-run             Preview queue without processing"
    echo "  --issue ID            Process a specific issue"
    echo "  --skip-spec           Skip spec generation"
    echo "  --max N               Override max issues per heartbeat"
    echo "  -m, --model MODEL     Claude model (default: $CW_MODEL)"
    echo "  -v, --verbose         Stream JSON output"
    echo "  -h, --help            Show this help"
    echo ""
    echo "Setup:"
    echo "  Run /cw-linear-init inside Claude to create .claude-workflow/config.yaml"
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --dry-run) DRY_RUN=true; shift ;;
        --issue) require_arg "--issue" "${2:-}"; ISSUE_ID="$2"; shift 2 ;;
        --skip-spec) SKIP_SPEC=true; shift ;;
        --max) require_arg "--max" "${2:-}"; MAX_OVERRIDE="$2"; shift 2 ;;
        -m|--model) require_arg "--model" "${2:-}"; CW_MODEL="$2"; shift 2 ;;
        -v|--verbose) CW_VERBOSE=true; shift ;;
        -h|--help) show_help; exit 0 ;;
        -*) log_error "Unknown option: $1"; show_help; exit 4 ;;
        *) log_error "Unexpected argument: $1"; show_help; exit 4 ;;
    esac
done

# =============================================================================
# Preflight Checks
# =============================================================================

check_jq || exit 4
check_claude || exit 4

CONFIG_FILE=".claude-workflow/config.yaml"
LOCK_FILE=".claude-workflow/heartbeat.lock"
LOG_FILE=".claude-workflow/heartbeat-log.jsonl"

if [ ! -f "$CONFIG_FILE" ]; then
    log_error "Linear integration not configured."
    log_info "Run /cw-linear-init inside Claude to set up .claude-workflow/config.yaml"
    exit 4
fi

print_banner "Claude Workflow - Heartbeat"

# =============================================================================
# Lock Management
# =============================================================================

acquire_lock() {
    if [ -f "$LOCK_FILE" ]; then
        local lock_time
        lock_time=$(jq -r '.started_at // empty' "$LOCK_FILE" 2>/dev/null || echo "")

        if [ -n "$lock_time" ]; then
            local lock_epoch
            lock_epoch=$(date -d "$lock_time" +%s 2>/dev/null || echo "0")
            local now_epoch
            now_epoch=$(date +%s)
            local age_hours=$(( (now_epoch - lock_epoch) / 3600 ))

            # Default stale threshold: 1 hour
            local stale_hours=1
            if [ "$age_hours" -lt "$stale_hours" ]; then
                log_error "Heartbeat already running (locked since $lock_time)"
                log_info "Lock will be considered stale after ${stale_hours}h"
                exit 0
            else
                log_warning "Stale lock detected (${age_hours}h old), clearing"
                rm -f "$LOCK_FILE"
            fi
        else
            log_warning "Corrupt lock file, clearing"
            rm -f "$LOCK_FILE"
        fi
    fi

    mkdir -p .claude-workflow
    echo "{\"pid\": $$, \"started_at\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"}" > "$LOCK_FILE"
}

release_lock() {
    rm -f "$LOCK_FILE"
}

# Ensure lock is released on exit
trap release_lock EXIT

# =============================================================================
# Main Execution
# =============================================================================

acquire_lock

# Build the heartbeat prompt for Claude
HEARTBEAT_ARGS=""
if [ "$DRY_RUN" = true ]; then
    HEARTBEAT_ARGS="$HEARTBEAT_ARGS --dry-run"
fi
if [ -n "$ISSUE_ID" ]; then
    HEARTBEAT_ARGS="$HEARTBEAT_ARGS --issue $ISSUE_ID"
fi
if [ "$SKIP_SPEC" = true ]; then
    HEARTBEAT_ARGS="$HEARTBEAT_ARGS --skip-spec"
fi
if [ -n "$MAX_OVERRIDE" ]; then
    HEARTBEAT_ARGS="$HEARTBEAT_ARGS --max $MAX_OVERRIDE"
fi

HEARTBEAT_PROMPT="Use the Skill tool to invoke 'cw-heartbeat' with args: '$HEARTBEAT_ARGS'.

Process the Linear issue queue according to .claude-workflow/config.yaml. This is running non-interactively — proceed autonomously without using AskUserQuestion."

log_info "Model: $CW_MODEL"
log_info "Dry run: $DRY_RUN"
if [ -n "$ISSUE_ID" ]; then
    log_info "Issue: $ISSUE_ID"
fi

if invoke_claude "$HEARTBEAT_PROMPT" "$CW_MODEL"; then
    log_success "Heartbeat completed"
    EXIT_CODE=0
else
    log_warning "Heartbeat completed with issues"
    EXIT_CODE=1
fi

exit $EXIT_CODE
