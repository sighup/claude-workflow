function formatElapsed(seconds) {
  const hours = Math.floor(seconds / 3600);
  const mins = Math.floor(seconds % 3600 / 60);
  const secs = seconds % 60;
  if (hours > 0) return `${hours}h ${mins}m`;
  if (mins > 0) return `${mins}m ${secs}s`;
  return `${secs}s`;
}

// src/core/session.ts
var CLAUDE_DIR = (0, import_node_path2.join)(process.env.HOME ?? "", ".claude");
var CLAUDE_TASKS_DIR = (0, import_node_path2.join)(CLAUDE_DIR, "tasks");
var CLAUDE_PROJECTS_DIR = (0, import_node_path2.join)(CLAUDE_DIR, "projects");
function encodeProjectPath(path) {
  return path.replace(/^\//, "-").replace(/\//g, "-");
}
function resolveTaskListId(projectPath) {
  if (process.env.CLAUDE_CODE_TASK_LIST_ID) {
    return process.env.CLAUDE_CODE_TASK_LIST_ID;
  }
  const localSettings = readJson(
    (0, import_node_path2.join)(projectPath, ".claude", "settings.local.json")
  );
  if (localSettings?.env?.CLAUDE_CODE_TASK_LIST_ID) {
    return localSettings.env.CLAUDE_CODE_TASK_LIST_ID;
  }
  const settings = readJson(
    (0, import_node_path2.join)(projectPath, ".claude", "settings.json")
  );
  if (settings?.env?.CLAUDE_CODE_TASK_LIST_ID) {
    return settings.env.CLAUDE_CODE_TASK_LIST_ID;
  }
  return null;
}
function hasJsonFiles(dir) {
  return listJsonFiles(dir).length > 0;
}
function warnCorruptTasks(tasksDir) {
  const files = listJsonFiles(tasksDir);
  let corrupt = 0;
  for (const f of files) {
    try {
      const content = require("node:fs").readFileSync(f, "utf-8");
      JSON.parse(content);
    } catch {
      corrupt++;
    }
  }
  if (corrupt > 0) {
    logWarning(`${corrupt} corrupt task file(s) will be skipped`);
  }
}
function discoverSession(projectPath = process.cwd()) {
  const taskListId = resolveTaskListId(projectPath);
  if (taskListId) {
    const tlDir = (0, import_node_path2.join)(CLAUDE_TASKS_DIR, taskListId);
    if ((0, import_node_fs2.existsSync)(tlDir) && hasJsonFiles(tlDir)) {
      logInfo(`Task list: ${taskListId}`);
      logInfo(`Tasks dir: ${tlDir}`);
      warnCorruptTasks(tlDir);
      return { sessionId: "", taskListId, tasksDir: tlDir };
    }
  }
  const encodedPath = encodeProjectPath(projectPath);
  const sessionsIndex = (0, import_node_path2.join)(CLAUDE_PROJECTS_DIR, encodedPath, "sessions-index.json");
  if (!(0, import_node_fs2.existsSync)(sessionsIndex)) {
    logError(`No sessions found for project: ${projectPath}`);
    return null;
  }
  const index = readJson(sessionsIndex);
  if (!index?.entries) {
    logError(`No session with tasks found for project: ${projectPath}`);
    return null;
  }
  const sorted = [...index.entries].sort(
    (a, b) => new Date(b.modified).getTime() - new Date(a.modified).getTime()
  );
  for (const entry of sorted) {
    const tasksDir = (0, import_node_path2.join)(CLAUDE_TASKS_DIR, entry.sessionId);
    if ((0, import_node_fs2.existsSync)(tasksDir)) {
      const contents = (0, import_node_fs2.readdirSync)(tasksDir);
      if (contents.length > 0) {
        logInfo(`Session: ${entry.sessionId}`);
        logInfo(`Tasks dir: ${tasksDir}`);
        warnCorruptTasks(tasksDir);
        return { sessionId: entry.sessionId, taskListId: "", tasksDir };
      }
    }
  }
  logError(`No session with tasks found for project: ${projectPath}`);
  return null;
}

// src/core/tasks.ts
var TaskStore = class {
  constructor(tasksDir) {
    this.tasksDir = tasksDir;
  }
  getAll() {
    const files = listJsonFiles(this.tasksDir);
    const tasks = [];
    for (const f of files) {
      const task = readJson(f);
      if (task && task.id && task.status) {
        tasks.push(task);
      }
    }
    return tasks;
  }
  getPendingUnblocked() {
    const all = this.getAll();
    const completedIds = new Set(all.filter((t) => t.status === "completed").map((t) => t.id));
    return all.filter((t) => {
      if (t.status !== "pending") return false;
      const blockers = t.blockedBy ?? [];
      return blockers.every((id) => completedIds.has(id));
    });
  }
  getNextTaskId() {
    const pending = this.getPendingUnblocked();
    if (pending.length === 0) return null;
    pending.sort((a, b) => {
      const aNum = parseInt(a.id, 10);
      const bNum = parseInt(b.id, 10);
      if (!isNaN(aNum) && !isNaN(bNum)) return aNum - bNum;
      return a.id.localeCompare(b.id);
    });
    return pending[0].id;
  }
  isComplete() {
    const all = this.getAll();
    if (all.length === 0) return false;
    return all.filter((t) => t.status === "pending").length === 0 && all.filter((t) => t.status === "in_progress").length === 0;
  }
  getCounts() {
    const all = this.getAll();
    return {
      total: all.length,
      completed: all.filter((t) => t.status === "completed").length,
      pending: all.filter((t) => t.status === "pending").length,
      in_progress: all.filter((t) => t.status === "in_progress").length,
      failed: all.filter((t) => (t.metadata?.failure_count ?? 0) > 0).length
    };
  }
  getCompletedCount() {
    return this.getAll().filter((t) => t.status === "completed").length;
  }
  getPendingFixCount() {
    return this.getAll().filter((t) => {
      if (t.status !== "pending") return false;
      const subj = t.subject ?? "";
      const taskId = t.metadata?.task_id ?? "";
      return /^FIX/i.test(subj) || /^FIX/i.test(taskId) || t.metadata?.fix_task_id != null;
    }).length;
  }
  getTestTaskCounts() {
    const tests = this.getTestTasks();
    return {
      total: tests.length,
      passed: tests.filter(
        (t) => t.metadata?.test_status === "passed" || t.status === "completed"
      ).length,
      failed: tests.filter(
        (t) => t.metadata?.test_status === "failed" || t.metadata?.test_status === "blocked"
      ).length,
      pending: tests.filter(
        (t) => t.metadata?.test_status === "pending" || t.metadata?.test_status == null && t.status === "pending"
      ).length
    };
  }
  getTestTasks() {
    return this.getAll().filter((t) => {
      if (t.metadata?.test_suite === true) return false;
      return t.metadata?.test_status != null || t.metadata?.test_type === "e2e" || /^TEST/i.test(t.subject ?? "") || /^TEST/i.test(t.metadata?.task_id ?? "");
    });
  }
  allTestsPassed() {
    const counts = this.getTestTaskCounts();
    return counts.total > 0 && counts.failed === 0 && counts.total === counts.passed;
  }
  getTaskSubject(taskId) {
    const task = readJson(`${this.tasksDir}/${taskId}.json`);
    return task?.subject ?? "";
  }
  getSpecPath() {
    const all = this.getAll();
    for (const t of all) {
      if (t.metadata?.spec_path) return t.metadata.spec_path;
    }
    return null;
  }
  // Display helpers
  printTaskStatus() {
    const counts = this.getCounts();
    console.log("");
    console.log(`  ${source_default.green("Completed:")}   ${counts.completed}/${counts.total}`);
    console.log(`  ${source_default.yellow("Pending:")}     ${counts.pending}`);
    console.log(`  ${source_default.blue("In Progress:")} ${counts.in_progress}`);
    console.log(`  ${source_default.red("Failed:")}      ${counts.failed}`);
    console.log("");
    if (counts.total > 0) {
      const pct = Math.floor(counts.completed * 100 / counts.total);
      console.log(`  Progress: ${source_default.green(`${pct}%`)}`);
      console.log("");
    }
  }
  showTaskList() {
    const all = this.getAll();
    if (all.length === 0) {
      console.log(source_default.yellow("  No tasks found."));
      return;
    }
    const lines = [];
    for (const t of all) {
      const id = t.metadata?.task_id ?? t.id;
      if (t.status === "completed") {
        lines.push(`  ${source_default.green("[\u2713]")} ${id}: ${t.subject}`);
      } else if ((t.metadata?.failure_count ?? 0) > 0) {
        lines.push(`  ${source_default.red("[\u2717]")} ${id}: ${t.subject}`);
      } else if (t.status === "in_progress") {
        lines.push(`  ${source_default.yellow("[~]")} ${id}: ${t.subject}`);
      } else {
        lines.push(`  [ ] ${id}: ${t.subject}`);
      }
    }
    lines.sort();
    for (const line of lines) console.log(line);
  }
  showFailedTasks() {
    const failed = this.getAll().filter((t) => (t.metadata?.failure_count ?? 0) > 0);
    if (failed.length === 0) {
      console.log("  (none)");
    } else {
      for (const t of failed) {
        console.log(`  [${t.metadata?.task_id ?? t.id}] ${t.subject}`);
      }
    }
  }
  showPendingUnblockedTasks() {
    const pending = this.getPendingUnblocked();
    if (pending.length === 0) {
      console.log("  (none - all pending tasks are blocked)");
    } else {
      for (const t of pending) {
        const complexity = t.metadata?.complexity ?? "unknown";
        console.log(`  [${t.metadata?.task_id ?? t.id}] ${t.subject} (complexity: ${complexity})`);
      }
    }
  }
};

// src/core/queue-store.ts
var import_node_path3 = require("node:path");
function generateId() {
  const now2 = /* @__PURE__ */ new Date();
  const date = now2.toISOString().slice(0, 10).replace(/-/g, "");
  const seq = String(Math.floor(Math.random() * 999) + 1).padStart(3, "0");
  return `${date}-${seq}`;
}
var QueueStore = class {
  constructor(queueDir) {
    this.queueDir = queueDir;
    ensureDir(queueDir);
  }
  add(item) {
    const full = {
      ...item,
      id: generateId(),
      created_at: (/* @__PURE__ */ new Date()).toISOString(),
      rate_limit_retries: 0
    };
    writeJson(this.itemPath(full.id), full);
    return full;
  }
  list(filter) {
    const files = listJsonFiles(this.queueDir);
    const items = [];
    for (const f of files) {
      const item = readJson(f);
      if (!item || !item.id) continue;
      if (filter?.status && item.status !== filter.status) continue;
      items.push(item);
    }
    items.sort((a, b) => a.priority - b.priority || a.created_at.localeCompare(b.created_at));
    return items;
  }
  get(id) {
    return readJson(this.itemPath(id));
  }
  update(id, patch) {
    const item = this.get(id);
    if (!item) return;
    writeJson(this.itemPath(id), { ...item, ...patch });
  }
  cancel(id) {
    const item = this.get(id);
    if (!item || item.status !== "pending") return false;
    this.update(id, { status: "cancelled" });
    return true;
  }
  retry(id) {
    const item = this.get(id);
    if (!item || item.status !== "failed" && item.status !== "rate_limited") return false;
    this.update(id, {
      status: "pending",
      started_at: void 0,
      completed_at: void 0,
      exit_code: void 0,
      pr_url: void 0,
      log_dir: void 0
    });
    return true;
  }
  getNextPending() {
    const pending = this.list({ status: "pending" });
    return pending[0] ?? null;
  }
  hasExistingSource(source) {
    return this.list().some((item) => item.source === source && item.status !== "cancelled");
  }
  itemPath(id) {
    return (0, import_node_path3.join)(this.queueDir, `${id}.json`);
  }
};

// src/util/config.ts
function envStr(key, def) {
  return process.env[key] ?? def;
}
function envInt(key, def) {
  const v = process.env[key];
  return v ? parseInt(v, 10) : def;
}
function envBool(key, def) {
  const v = process.env[key];
  if (!v) return def;
  return v === "true" || v === "1";
}
function envList(key, def) {
  const v = process.env[key];
  if (!v) return def;
  return v.split(/\s+/).filter(Boolean);
}
