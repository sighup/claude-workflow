// src/core/history-store.ts
var import_node_path7 = require("node:path");
var import_node_fs6 = require("node:fs");
var HistoryStore = class {
  constructor(logDir) {
    this.logDir = logDir;
    ensureDir(logDir);
  }
  createRun(projectDir) {
    const now2 = /* @__PURE__ */ new Date();
    const id = now2.toISOString().replace(/[:.]/g, "-").slice(0, 19);
    const record = {
      id,
      started_at: now2.toISOString(),
      items_processed: 0,
      items_succeeded: 0,
      items_failed: 0,
      pr_urls: [],
      project_dir: projectDir
    };
    const runDir = (0, import_node_path7.join)(this.logDir, id);
    ensureDir(runDir);
    writeJson((0, import_node_path7.join)(runDir, "run.json"), record);
    return record;
  }
  updateRun(id, patch) {
    const runDir = (0, import_node_path7.join)(this.logDir, id);
    const runFile = (0, import_node_path7.join)(runDir, "run.json");
    const record = readJson(runFile);
    if (!record) return;
    writeJson(runFile, { ...record, ...patch });
  }
  completeRun(id, results) {
    const now2 = /* @__PURE__ */ new Date();
    const runDir = (0, import_node_path7.join)(this.logDir, id);
    const runFile = (0, import_node_path7.join)(runDir, "run.json");
    const record = readJson(runFile);
    if (!record) return;
    const started = new Date(record.started_at);
    const duration = Math.floor((now2.getTime() - started.getTime()) / 1e3);
    writeJson(runFile, {
      ...record,
      ...results,
      completed_at: now2.toISOString(),
      duration_seconds: duration
    });
  }
  list(limit) {
    if (!fileExists(this.logDir)) return [];
    const dirs = (0, import_node_fs6.readdirSync)(this.logDir, { withFileTypes: true }).filter((d) => d.isDirectory()).map((d) => d.name).sort().reverse();
    const records = [];
    for (const dir of dirs.slice(0, limit)) {
      const record = readJson((0, import_node_path7.join)(this.logDir, dir, "run.json"));
      if (record) records.push(record);
    }
    return records;
  }
  show(id) {
    return readJson((0, import_node_path7.join)(this.logDir, id, "run.json"));
  }
  clean(olderThanDays) {
    if (!fileExists(this.logDir)) return 0;
    const cutoff = Date.now() - olderThanDays * 24 * 60 * 60 * 1e3;
    const dirs = (0, import_node_fs6.readdirSync)(this.logDir, { withFileTypes: true }).filter((d) => d.isDirectory());
    let removed = 0;
    for (const dir of dirs) {
      const fullPath = (0, import_node_path7.join)(this.logDir, dir.name);
      try {
        const idDate = new Date(dir.name.replace(/-/g, (m, offset) => {
          if (offset > 12) return ":";
          return m;
        }));
        if (idDate.getTime() < cutoff) {
          (0, import_node_fs6.rmSync)(fullPath, { recursive: true });
          removed++;
        }
      } catch {
      }
    }
    return removed;
  }
};

// src/commands/history.ts
var historyCommand = new Command("history").description("Execution history viewer");
historyCommand.command("list").description("Show recent runs").option("--last <n>", "Number of runs to show", "10").action((opts) => {
  const config = loadConfig();
  const store = new HistoryStore(config.autoLogDir);
  const runs = store.list(parseInt(opts.last));
  if (runs.length === 0) {
    logInfo("No execution history found");
    return;
  }
  for (const run of runs) {
    const status = run.items_failed > 0 ? source_default.red("FAIL") : source_default.green("PASS");
    const duration = run.duration_seconds ? formatElapsed(run.duration_seconds) : "running";
    const prs = run.pr_urls.length > 0 ? ` | PRs: ${run.pr_urls.length}` : "";
    console.log(
      `  ${status} ${run.id} | ${run.items_succeeded}/${run.items_processed} succeeded | ${duration}${prs}`
    );
  }
});
historyCommand.command("show").description("Show detailed run report").argument("<run-id>", "Run ID").action((runId) => {
  const config = loadConfig();
  const store = new HistoryStore(config.autoLogDir);
  const run = store.show(runId);
  if (!run) {
    logInfo(`Run not found: ${runId}`);
    return;
  }
  console.log(JSON.stringify(run, null, 2));
});
historyCommand.command("clean").description("Prune old runs").option("--older-than <days>", "Days to keep", "30").action((opts) => {
  const config = loadConfig();
  const store = new HistoryStore(config.autoLogDir);
  const removed = store.clean(parseInt(opts.olderThan));
  logSuccess(`Removed ${removed} old run(s)`);
});

// src/commands/auto.ts
var import_node_path9 = require("node:path");
