// src/util/fs.ts
var import_node_fs = require("node:fs");
var import_node_path = require("node:path");
function readJson(path) {
  try {
    return JSON.parse((0, import_node_fs.readFileSync)(path, "utf-8"));
  } catch {
    return null;
  }
}
function writeJson(path, data) {
  (0, import_node_fs.mkdirSync)((0, import_node_path.dirname)(path), { recursive: true });
  (0, import_node_fs.writeFileSync)(path, JSON.stringify(data, null, 2) + "\n");
}
function fileExists(path) {
  return (0, import_node_fs.existsSync)(path);
}
function listJsonFiles(dir) {
  if (!(0, import_node_fs.existsSync)(dir)) return [];
  return (0, import_node_fs.readdirSync)(dir).filter((f) => f.endsWith(".json")).map((f) => (0, import_node_path.join)(dir, f));
}
function ensureDir(dir) {
  (0, import_node_fs.mkdirSync)(dir, { recursive: true });
}
function findLatestFile(dir, pattern, exclude) {
  if (!(0, import_node_fs.existsSync)(dir)) return null;
  const files = [];
  function walk(d) {
    for (const entry of (0, import_node_fs.readdirSync)(d, { withFileTypes: true })) {
      const full = (0, import_node_path.join)(d, entry.name);
      if (entry.isDirectory()) {
        walk(full);
      } else if (pattern.test(entry.name) && (!exclude || !exclude.test(entry.name))) {
        files.push({ path: full, mtime: (0, import_node_fs.statSync)(full).mtimeMs });
      }
    }
  }
  walk(dir);
  if (files.length === 0) return null;
  files.sort((a, b) => b.mtime - a.mtime);
  return files[0].path;
}

